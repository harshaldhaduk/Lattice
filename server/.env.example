# ── Required ───────────────────────────────────────────────────────────────────
# Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Optional ───────────────────────────────────────────────────────────────────
# Server port (default: 3001)
PORT=3001

# SQLite database path — set to :memory: in tests
LATTICE_DB_PATH=

# GitHub Personal Access Token (scopes: repo) — required for /sync endpoint
GITHUB_TOKEN=

# Absolute path to the claude CLI binary (default: resolves 'claude' on PATH)
CLAUDE_PATH=

# Demo repo password — used only by demo-repo/src/api/users.ts
DEMO_PASSWORD=change-me-before-demo
