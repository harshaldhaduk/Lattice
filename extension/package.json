{
  "name": "lattice-vscode",
  "displayName": "Lattice",
  "description": "AI-native coordination layer for parallel development teams",
  "version": "0.0.1",
  "publisher": "lattice",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "AI"
  ],
  "keywords": [
    "collaboration",
    "AI",
    "multiplayer",
    "coordination",
    "agents"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "lattice.createSession",
        "title": "Lattice: Create Session"
      },
      {
        "command": "lattice.joinSession",
        "title": "Lattice: Join Session"
      },
      {
        "command": "lattice.registerIntent",
        "title": "Lattice: Register Intent"
      },
      {
        "command": "lattice.endSession",
        "title": "Lattice: End Session"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "lattice-sidebar",
          "title": "Lattice",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "lattice-sidebar": [
        {
          "type": "webview",
          "id": "lattice.sidebarView",
          "name": "Lattice"
        }
      ]
    },
    "configuration": {
      "title": "Lattice",
      "properties": {
        "lattice.serverUrl": {
          "type": "string",
          "default": "http://localhost:3001",
          "description": "Lattice coordination server URL"
        }
      }
    }
  },
  "scripts": {
    "dev": "node esbuild.mjs --watch",
    "build": "node esbuild.mjs",
    "package": "node esbuild.mjs && node -e \"const{execSync:e,mkdtempSync:m}=require('child_process'),{cpSync:c}=require('fs'),t=m(require('os').tmpdir()+'/lattice-pkg-');c('package.json',t+'/package.json');c('out',t+'/out',{recursive:true});c('media',t+'/media',{recursive:true});require('fs').writeFileSync(t+'/.vscodeignore','**\\n!package.json\\n!media/**\\n!out/extension.js');e('npx @vscode/vsce package --out '+process.cwd()+'/../lattice.vsix --allow-missing-repository',{cwd:t,stdio:'inherit'});\""
  },
  "dependencies": {},
  "devDependencies": {
    "@lattice/shared": "*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.27.7",
    "socket.io-client": "^4.7.5",
    "typescript": "^5.4.5"
  }
}
